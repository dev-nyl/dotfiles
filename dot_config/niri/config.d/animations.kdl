/// BASE
animations {
	slowdown 1

	window-open {
		spring damping-ratio=0.8 stiffness=900 epsilon=0.0001
	}
	
	window-close {
		spring damping-ratio=0.8 stiffness=900 epsilon=0.0001
	}

	window-resize {
		spring damping-ratio=0.8 stiffness=900 epsilon=0.0001
	}

	window-movement {
		spring damping-ratio=0.8 stiffness=900 epsilon=0.0001
	}

	workspace-switch {
		spring damping-ratio=0.8 stiffness=300 epsilon=0.0001
	}

	horizontal-view-movement {
		spring damping-ratio=0.8 stiffness=300 epsilon=0.0001
	}

	config-notification-open-close {
		spring damping-ratio=0.8 stiffness=300 epsilon=0.0001
	}

	screenshot-ui-open {
		spring damping-ratio=0.8 stiffness=300 epsilon=0.0001
	}
}

/// SHADERS
include "shaders/open/blur-glitch.kdl"
include "shaders/close/blur-glitch.kdl"
include "shaders/resize/aberration.kdl"


binds {
	// MACROPAD LAYER 1: AUDIO
	// KNOBS
	XF86AudioRaiseVolume		allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02+ -l 1.0"; }
	XF86AudioLowerVolume		allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02-"; }
	XF86AudioPlay			allow-when-locked=true { spawn-sh "mpc toggle"; }
	XF86AudioPrev			allow-when-locked=true { spawn-sh "mpc prev"; }
	XF86AudioNext			allow-when-locked=true { spawn-sh "mpc next"; }
	XF86AudioRewind			allow-when-locked=true { spawn-sh "mpc seek -1%"; }
	XF86AudioForward		allow-when-locked=true { spawn-sh "mpc seek +1%"; }
	Shift+XF86AudioRaiseVolume	allow-when-locked=true { spawn-sh "mpc volume +2"; }
	Shift+XF86AudioLowerVolume	allow-when-locked=true { spawn-sh "mpc volume -2"; }

	// ROW 1 [QUEUE CONTROLS]
	XF86Tools			allow-when-locked=true { spawn-sh "mpc repeat"; }
	XF86Launch5			allow-when-locked=true { spawn-sh "mpc random"; }
	XF86Launch6			allow-when-locked=true { spawn-sh "mpc consume"; }
	XF86Launch7			allow-when-locked=true { spawn-sh "mpc single"; }

	// ROW 2 [LOADING QUEUES]
	XF86Launch8			allow-when-locked=true { spawn-sh "~/.sh/mmpc load-tmp-pl"; }
	XF86Launch9			allow-when-locked=true { spawn-sh "~/.sh/mmpc load-album"; }
	F19				allow-when-locked=true { spawn-sh "~/.sh/mmpc load-artist"; }
	XF86AudioMicMute		allow-when-locked=true { spawn-sh "~/.sh/mmpc load-all"; }

	// ROW 3 [TMP PLAYLIST CONTROLS]
	XF86TouchpadToggle		allow-when-locked=true { spawn-sh "~/.sh/mmpc add-tmp-pl"; }
	XF86TouchpadOn			allow-when-locked=true { spawn-sh "~/.sh/mmpc mv-prev-tmp-pl"; }
	F23				allow-when-locked=true { spawn-sh "~/.sh/mmpc mv-next-tmp-pl"; }
	F24				allow-when-locked=true { spawn-sh "~/.sh/mmpc del-tmp-pl"; }
}
